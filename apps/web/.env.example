# =============================================================
# StageLink Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4001

# WorkOS AuthKit (required when auth is implemented — T2)
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:4000/api/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:4000/api/auth/callback
