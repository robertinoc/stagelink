# =============================================================
# StageLink Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================

# App URLs
# Production: https://stagelink.art
# Staging: https://staging.stagelink.link
NEXT_PUBLIC_APP_URL=http://localhost:4000

# API URL — points to NestJS backend (Railway in production)
# Production: https://stagelink-production-18c8.up.railway.app
# Future custom API domain: https://api.stagelink.link
# Public: safe to expose to browser code.
NEXT_PUBLIC_API_URL=http://localhost:4001

# Server-only API URL for SSR (not exposed to the browser).
# Used by Server Components and Route Handlers to avoid exposing private/internal API URLs.
# Defaults to NEXT_PUBLIC_API_URL value in development.
API_URL=http://localhost:4001

# WorkOS AuthKit — required
# Get these from https://dashboard.workos.com → Your app → API Keys
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The callback URL must be registered in WorkOS Dashboard:
#   Authentication → Redirect URIs → Add URI
# Local:       http://localhost:4000/api/auth/callback
# Production:  https://stagelink.art/api/auth/callback
WORKOS_REDIRECT_URI=http://localhost:4000/api/auth/callback

# Cookie encryption key — must be at least 32 characters
# Generate with: openssl rand -base64 32
# KEEP SECRET: rotating this invalidates all active sessions
WORKOS_COOKIE_PASSWORD=CHANGE_ME_USE_AT_LEAST_32_CHARACTERS_HERE
# Optional production cookie domain. Enables shared sessions for behind.stagelink.art.
# Use only when all authenticated hosts are under stagelink.art.
WORKOS_COOKIE_DOMAIN=

# Behind the Stage admin allowlist — server-only, comma-separated WorkOS emails.
BEHIND_ADMIN_EMAILS=
# Emergency diagnostic flag for /api/admin/debug/headers. Keep false/unset by default.
BEHIND_DEBUG_HEADERS_ENABLED=false

# Landing contact form delivery — Resend via /api/contact.
# Server-only: do not prefix with NEXT_PUBLIC_.
RESEND_API_KEY=
CONTACT_FORM_TO=support@stagelink.art
CONTACT_FORM_FROM=StageLink <onboarding@resend.dev>

# Public artist contact blocks — EmailJS (https://www.emailjs.com/)
# Public keys: safe to expose to browser code. Required only when the
# Contact Form block should send mail directly from public artist pages.
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Behind role persistence — server-only Upstash Redis REST credentials.
UPSTASH_REDIS_KV_REST_API_URL=
UPSTASH_REDIS_KV_REST_API_TOKEN=

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Explicit deployment tier for analytics filtering (development | staging | production).
# NODE_ENV is 'production' on staging servers — this disambiguates them.
NEXT_PUBLIC_APP_ENV=development

# Umami Analytics (optional)
# Product/platform analytics. The script is not loaded unless a website ID is set.
NEXT_PUBLIC_UMAMI_PLATFORM_WEBSITE_ID=
# Optional public/share URL used to embed the Umami dashboard inside /behind/analytics.
NEXT_PUBLIC_UMAMI_PLATFORM_SHARE_URL=
# Cloud default: https://cloud.umami.is/script.js. Set this for a self-hosted Umami instance.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# Optional self-hosted collection endpoint, e.g. https://umami.stagelink.io.
NEXT_PUBLIC_UMAMI_HOST_URL=
# Comma-separated domains accepted by the tracker.
NEXT_PUBLIC_UMAMI_DOMAINS=stagelink.art,www.stagelink.art

# Artist image delivery hostname — used for next/image remotePatterns.
# Set to the hostname of your AWS_S3_PUBLIC_BASE_URL (API side).
# e.g. "your-bucket.s3.us-east-1.amazonaws.com" or "cdn.stagelink.io"
NEXT_PUBLIC_IMAGES_HOSTNAME=

# AI Translation (optional) — enables the auto-translate button in Profile and Press Kit
# Get your key from https://platform.openai.com/api-keys
# Server-only: do not prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=
# Model used for translation — defaults to gpt-4o-mini if not set
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
