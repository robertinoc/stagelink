// =============================================================
// StageLink — Prisma Schema
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AssetKind {
  avatar
  cover

  @@map("asset_kind")
}

enum ArtistCategory {
  musician
  dj
  actor
  painter
  visual_artist
  performer
  creator
  band
  producer
  other

  @@map("artist_category")
}

enum ArtistRole {
  owner
  admin
  editor
  viewer

  @@map("artist_role")
}

enum AssetStatus {
  pending
  uploaded
  failed
  deleted

  @@map("asset_status")
}

// =============================================================
// USERS
// Cuenta de plataforma vinculada a WorkOS.
// Un user puede tener uno o más artists (MVP: uno por user).
// =============================================================
model User {
  id          String   @id @default(cuid())
  workosId    String   @unique @map("workos_id")
  email       String   @unique
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  artists     Artist[]
  assets      Asset[]  @relation("UserAssets")
  memberships ArtistMembership[]
  auditLogs   AuditLog[]

  @@map("users")
}

// =============================================================
// ARTISTS
// Perfil artístico con username único (clave multi-tenant).
// =============================================================
model Artist {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  username    String   @unique
  displayName String   @map("display_name")
  bio         String?
  category    ArtistCategory @default(other) @map("category")
  avatarUrl     String?  @map("avatar_url")
  coverUrl      String?  @map("cover_url")
  avatarAssetId String?  @unique @map("avatar_asset_id")
  coverAssetId  String?  @unique @map("cover_asset_id")
  // Social links
  instagramUrl  String?  @map("instagram_url")
  tiktokUrl     String?  @map("tiktok_url")
  youtubeUrl    String?  @map("youtube_url")
  spotifyUrl    String?  @map("spotify_url")
  soundcloudUrl String?  @map("soundcloud_url")
  websiteUrl    String?  @map("website_url")
  contactEmail  String?  @map("contact_email")
  // SEO
  seoTitle      String?  @map("seo_title")
  seoDescription String? @map("seo_description")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  page            Page?
  subscription    Subscription?
  analyticsEvents AnalyticsEvent[]
  customDomains   CustomDomain[]
  assets          Asset[]  @relation("ArtistAssets")
  avatarAsset     Asset?   @relation("ArtistAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  coverAsset      Asset?   @relation("ArtistCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  memberships     ArtistMembership[]
  smartLinks      SmartLink[]
  subscribers     Subscriber[]

  @@map("artists")
}

// =============================================================
// ARTIST MEMBERSHIPS
// Fuente de verdad para autorización multi-usuario por artista.
// Reemplaza la comprobación artist.userId === user.id.
// =============================================================
model ArtistMembership {
  id        String     @id @default(cuid())
  artistId  String     @map("artist_id")
  userId    String     @map("user_id")
  role      ArtistRole @default(viewer)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistId, userId])
  @@map("artist_memberships")
}

// =============================================================
// AUDIT LOGS
// Registro inmutable de acciones sensibles. Fire-and-forget.
// =============================================================
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// =============================================================
// PAGES
// Página pública del artista (configuración, visibilidad).
// Relación 1-to-1 con Artist.
// =============================================================
model Page {
  id          String   @id @default(cuid())
  artistId    String   @unique @map("artist_id")
  title       String?
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  artist      Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  blocks      Block[]
  subscribers Subscriber[]

  @@map("pages")
}

// =============================================================
// BLOCKS
// Bloques de contenido ordenados en la página pública.
// Discriminated union vía el campo `type` + config JSON validada
// server-side según el tipo (ver blocks/schemas/block-config.schema.ts).
// =============================================================
enum BlockType {
  links
  music_embed
  video_embed
  email_capture

  @@map("block_type")
}

model Block {
  id          String    @id @default(cuid())
  pageId      String    @map("page_id")
  type        BlockType
  title       String?   // Etiqueta visible opcional (display label)
  config      Json      @default("{}") // Shape validado por tipo en el backend
  position    Int       @default(0)
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  page        Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  clickEvents AnalyticsEvent[]
  subscribers Subscriber[]

  @@index([pageId, position])
  @@map("blocks")
}

// =============================================================
// ANALYTICS EVENTS
// Raw events: page_view, link_click, smart_link_resolution, fan_capture_submit.
// IP hashed (SHA-256) to enable deduplication without storing PII.
// Link-specific fields (linkItemId, label, etc.) are null for page_view.
// =============================================================
enum EventType {
  page_view
  link_click
  smart_link_resolution
  fan_capture_submit

  @@map("event_type")
}

// T4-4: Typed enum for analytics event environment.
// Using an enum instead of a plain String prevents silent misspellings
// (e.g. 'prod', 'test') that would cause events to escape quality filtering.
enum AnalyticsEnvironment {
  production
  staging
  development

  @@map("analytics_environment")
}

model AnalyticsEvent {
  id          String    @id @default(cuid())
  artistId    String    @map("artist_id")
  blockId     String?   @map("block_id")      // link_click only
  eventType   EventType @map("event_type")
  ipHash      String    @map("ip_hash")        // SHA-256(ip) — deduplication
  country     String?
  device      String?
  // Link-specific fields — null for page_view events
  linkItemId  String?   @map("link_item_id")  // link_click / smart_link_resolution
  label       String?                           // human-readable link label
  isSmartLink Boolean   @default(false) @map("is_smart_link")
  smartLinkId String?   @map("smart_link_id") // when isSmartLink = true
  createdAt   DateTime  @default(now()) @map("created_at")

  // ─── Quality flags (T4-4) ──────────────────────────────────────────────────
  // Persist everything; filter at query time for clean dashboard metrics.
  // All flags default to the "clean" value so historical rows remain valid.
  isBotSuspected     Boolean              @default(false) @map("is_bot_suspected")
  isInternal         Boolean              @default(false) @map("is_internal")
  isQa               Boolean              @default(false) @map("is_qa")
  hasTrackingConsent Boolean?             @map("has_tracking_consent") // null = unknown (server-side events)
  environment        AnalyticsEnvironment @default(production)         // enum-typed: production | staging | development

  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  block   Block?  @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([artistId, createdAt])
  @@index([artistId, eventType, createdAt])
  @@index([artistId, linkItemId, createdAt], map: "analytics_events_artist_link_idx")
  @@index([artistId, isBotSuspected, isInternal, isQa, environment], map: "analytics_events_quality_flags_idx")
  @@map("analytics_events")
}

// =============================================================
// SUBSCRIBERS
// Fans que dejaron su email en un bloque email_capture.
//
// Unique constraint: [artistId, email] — un fan no puede suscribirse
// dos veces al mismo artista, pero sí a artistas distintos.
// =============================================================
enum SubscriberStatus {
  active
  unsubscribed

  @@map("subscriber_status")
}

model Subscriber {
  id             String           @id @default(cuid())
  artistId       String           @map("artist_id")
  blockId        String           @map("block_id")       // source block (for attribution)
  pageId         String?          @map("page_id")        // page that hosted the block
  email          String
  status         SubscriberStatus @default(active)
  consent        Boolean          @default(false)        // explicit consent given
  consentText    String?          @map("consent_text")   // snapshot of label shown
  ipHash         String?          @map("ip_hash")        // SHA-256(ip) — privacy-safe
  sourcePagePath String?          @map("source_page_path") // URL path at submit time
  locale         String?                                  // visitor locale
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  // Restrict: deleting a block must not silently destroy subscriber data.
  // The artist's email list must be preserved even if the capture block is removed.
  block  Block  @relation(fields: [blockId], references: [id], onDelete: Restrict)
  page   Page?  @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@unique([artistId, email], map: "subscribers_artist_id_email_key")
  @@index([artistId, createdAt(sort: Desc)], map: "subscribers_artist_id_created_at_idx")
  @@index([artistId, status], map: "subscribers_artist_id_status_idx")
  @@map("subscribers")
}

// =============================================================
// CUSTOM DOMAINS
// Dominios personalizados vinculados a un artista.
// La resolución actual es por username (/[username]).
// Este modelo deja preparada la arquitectura para resolución
// por dominio (e.g. robertinoc.com → artist).
// La activación real (DNS verification, SSL) se implementa después.
// =============================================================
enum CustomDomainStatus {
  pending   // Registrado, esperando verificación DNS
  active    // Verificado y resolviendo correctamente
  failed    // Verificación falló
  disabled  // Desactivado manualmente

  @@map("custom_domain_status")
}

model CustomDomain {
  id        String             @id @default(cuid())
  artistId  String             @map("artist_id")
  domain    String             @unique // Normalizado: lowercase, sin www, sin trailing slash
  isPrimary Boolean            @default(false) @map("is_primary")
  status    CustomDomainStatus @default(pending)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([domain, status])
  @@map("custom_domains")
}

// =============================================================
// SUBSCRIPTIONS
// Estado de suscripción Stripe por artista.
// =============================================================
enum PlanTier {
  free
  pro
  pro_plus

  @@map("plan_tier")
}

enum SubscriptionStatus {
  inactive
  active
  canceled
  past_due
  trialing
  incomplete

  @@map("subscription_status")
}

model Subscription {
  id                   String             @id @default(cuid())
  artistId             String             @unique @map("artist_id")
  plan                 PlanTier           @default(free)
  status               SubscriptionStatus @default(inactive)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  stripePriceId        String?            @map("stripe_price_id")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// =============================================================
// STRIPE WEBHOOK EVENTS
// Registro mínimo de eventos Stripe procesados para garantizar
// idempotencia por event.id ante reintentos.
// =============================================================
model StripeWebhookEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique @map("stripe_event_id")
  stripeEventType String   @map("stripe_event_type")
  artistId        String?  @map("artist_id")
  processedAt     DateTime @default(now()) @map("processed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([artistId, processedAt])
  @@map("stripe_webhook_events")
}

// =============================================================
// SMART LINKS
// Un SmartLink es una URL corta única que redirige a distintos
// destinos según la plataforma del visitante (iOS/Android/desktop).
// Las destinations se almacenan como JSON array validado server-side.
// =============================================================
model SmartLink {
  id           String   @id @default(cuid())
  artistId     String   @map("artist_id")
  label        String   // Nombre interno del artista, ej. "Nuevo álbum"
  destinations Json     @default("[]") // SmartLinkDestination[]
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@map("smart_links")
}

// =============================================================
// ASSETS
// Archivos subidos por artistas (avatar, cover, etc.).
// El backend controla el object key y el presigned URL.
// El cliente nunca sube directamente con credenciales propias.
// =============================================================
model Asset {
  id               String      @id @default(cuid())
  artistId         String      @map("artist_id")
  kind             AssetKind
  storageProvider  String      @default("s3") @map("storage_provider")
  bucket           String
  objectKey        String      @unique @map("object_key")
  originalFilename String?     @map("original_filename")
  mimeType         String      @map("mime_type")
  sizeBytes        Int         @map("size_bytes")
  deliveryUrl      String?     @map("delivery_url")
  status           AssetStatus @default(pending)
  createdByUserId  String      @map("created_by_user_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  artist        Artist  @relation("ArtistAssets", fields: [artistId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("UserAssets", fields: [createdByUserId], references: [id])
  avatarArtist  Artist? @relation("ArtistAvatar")
  coverArtist   Artist? @relation("ArtistCover")

  @@index([artistId, kind])
  @@map("assets")
}
