// =============================================================
// StageLink — Prisma Schema
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetKind {
  avatar
  cover

  @@map("asset_kind")
}

enum ArtistCategory {
  musician
  dj
  actor
  painter
  visual_artist
  performer
  creator
  band
  producer
  other

  @@map("artist_category")
}

enum ArtistRole {
  owner
  admin
  editor
  viewer

  @@map("artist_role")
}

enum AssetStatus {
  pending
  uploaded
  failed
  deleted

  @@map("asset_status")
}

// =============================================================
// USERS
// Cuenta de plataforma vinculada a WorkOS.
// Un user puede tener uno o más artists (MVP: uno por user).
// =============================================================
model User {
  id          String   @id @default(cuid())
  workosId    String   @unique @map("workos_id")
  email       String   @unique
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  artists     Artist[]
  assets      Asset[]  @relation("UserAssets")
  memberships ArtistMembership[]
  auditLogs   AuditLog[]

  @@map("users")
}

// =============================================================
// ARTISTS
// Perfil artístico con username único (clave multi-tenant).
// =============================================================
model Artist {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  username    String   @unique
  displayName String   @map("display_name")
  bio         String?
  category    ArtistCategory @default(other) @map("category")
  avatarUrl     String?  @map("avatar_url")
  coverUrl      String?  @map("cover_url")
  avatarAssetId String?  @unique @map("avatar_asset_id")
  coverAssetId  String?  @unique @map("cover_asset_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  page            Page?
  subscription    Subscription?
  analyticsEvents AnalyticsEvent[]
  customDomains   CustomDomain[]
  assets          Asset[]  @relation("ArtistAssets")
  avatarAsset     Asset?   @relation("ArtistAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  coverAsset      Asset?   @relation("ArtistCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  memberships     ArtistMembership[]

  @@map("artists")
}

// =============================================================
// ARTIST MEMBERSHIPS
// Fuente de verdad para autorización multi-usuario por artista.
// Reemplaza la comprobación artist.userId === user.id.
// =============================================================
model ArtistMembership {
  id        String     @id @default(cuid())
  artistId  String     @map("artist_id")
  userId    String     @map("user_id")
  role      ArtistRole @default(viewer)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistId, userId])
  @@map("artist_memberships")
}

// =============================================================
// AUDIT LOGS
// Registro inmutable de acciones sensibles. Fire-and-forget.
// =============================================================
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// =============================================================
// PAGES
// Página pública del artista (configuración, visibilidad).
// Relación 1-to-1 con Artist.
// =============================================================
model Page {
  id          String   @id @default(cuid())
  artistId    String   @unique @map("artist_id")
  title       String?
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  blocks  Block[]

  @@map("pages")
}

// =============================================================
// BLOCKS
// Bloques de contenido ordenados en la página pública.
// Discriminated union vía el campo `type`.
// =============================================================
enum BlockType {
  link
  music
  video
  fan_capture

  @@map("block_type")
}

model Block {
  id        String    @id @default(cuid())
  pageId    String    @map("page_id")
  type      BlockType
  title     String?
  url       String?
  position  Int       @default(0)
  isVisible Boolean   @default(true) @map("is_visible")
  metadata  Json?     // Datos extra por tipo (ej: embedId para música/video)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  page        Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  clickEvents AnalyticsEvent[]
  subscribers Subscriber[]

  @@index([pageId, position])
  @@map("blocks")
}

// =============================================================
// ANALYTICS EVENTS
// Eventos crudos de page_view y link_click.
// IP hasheada para deduplicación sin almacenar PII.
// =============================================================
enum EventType {
  page_view
  link_click

  @@map("event_type")
}

model AnalyticsEvent {
  id         String    @id @default(cuid())
  artistId   String    @map("artist_id")
  blockId    String?   @map("block_id")   // Solo para link_click
  eventType  EventType @map("event_type")
  ipHash     String    @map("ip_hash")    // SHA-256 de IP — deduplicación
  country    String?
  device     String?
  createdAt  DateTime  @default(now()) @map("created_at")

  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  block   Block?  @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([artistId, createdAt])
  @@index([artistId, eventType, createdAt])
  @@map("analytics_events")
}

// =============================================================
// SUBSCRIBERS
// Emails capturados vía bloque fan_capture.
// =============================================================
model Subscriber {
  id        String   @id @default(cuid())
  blockId   String   @map("block_id")
  email     String
  consent   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, email])
  @@map("subscribers")
}

// =============================================================
// CUSTOM DOMAINS
// Dominios personalizados vinculados a un artista.
// La resolución actual es por username (/[username]).
// Este modelo deja preparada la arquitectura para resolución
// por dominio (e.g. robertinoc.com → artist).
// La activación real (DNS verification, SSL) se implementa después.
// =============================================================
enum CustomDomainStatus {
  pending   // Registrado, esperando verificación DNS
  active    // Verificado y resolviendo correctamente
  failed    // Verificación falló
  disabled  // Desactivado manualmente

  @@map("custom_domain_status")
}

model CustomDomain {
  id        String             @id @default(cuid())
  artistId  String             @map("artist_id")
  domain    String             @unique // Normalizado: lowercase, sin www, sin trailing slash
  isPrimary Boolean            @default(false) @map("is_primary")
  status    CustomDomainStatus @default(pending)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([domain, status])
  @@map("custom_domains")
}

// =============================================================
// SUBSCRIPTIONS
// Estado de suscripción Stripe por artista.
// =============================================================
enum PlanTier {
  free
  pro
  pro_plus

  @@map("plan_tier")
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete

  @@map("subscription_status")
}

model Subscription {
  id                   String             @id @default(cuid())
  artistId             String             @unique @map("artist_id")
  plan                 PlanTier           @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// =============================================================
// ASSETS
// Archivos subidos por artistas (avatar, cover, etc.).
// El backend controla el object key y el presigned URL.
// El cliente nunca sube directamente con credenciales propias.
// =============================================================
model Asset {
  id               String      @id @default(cuid())
  artistId         String      @map("artist_id")
  kind             AssetKind
  storageProvider  String      @default("s3") @map("storage_provider")
  bucket           String
  objectKey        String      @unique @map("object_key")
  originalFilename String?     @map("original_filename")
  mimeType         String      @map("mime_type")
  sizeBytes        Int         @map("size_bytes")
  deliveryUrl      String?     @map("delivery_url")
  status           AssetStatus @default(pending)
  createdByUserId  String      @map("created_by_user_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  artist        Artist  @relation("ArtistAssets", fields: [artistId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("UserAssets", fields: [createdByUserId], references: [id])
  avatarArtist  Artist? @relation("ArtistAvatar")
  coverArtist   Artist? @relation("ArtistCover")

  @@index([artistId, kind])
  @@map("assets")
}
