{
  "name": "@stagelink/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage",
    "test:integration": "NODE_ENV=test DATABASE_URL=${DATABASE_URL:-postgresql://stagelink:stagelink@localhost:5432/stagelink_test} DIRECT_URL=${DIRECT_URL:-postgresql://stagelink:stagelink@localhost:5432/stagelink_test} jest --config ./jest.integration.config.ts --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "seed:demo-analytics": "ts-node -r tsconfig-paths/register src/scripts/seed-demo-analytics.ts",
    "seed:demo-analytics:cleanup": "ts-node -r tsconfig-paths/register src/scripts/cleanup-demo-analytics.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^5.22.0",
    "@stagelink/types": "workspace:*",
    "@workos-inc/node": "^8.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "joi": "^17.13.3",
    "jose": "^6.2.2",
    "posthog-node": "^5.28.9",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@stagelink/config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20",
    "@types/supertest": "^7.2.0",
    "eslint": "^9",
    "jest": "^29.0.0",
    "jest-junit": "^17.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.0"
  }
}
