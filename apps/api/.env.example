# =============================================================
# StageLink API — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================

# Application
NODE_ENV=development
PORT=4001
APP_URL=http://localhost:4001
FRONTEND_URL=http://localhost:4000

# PostgreSQL (required in production)
# Local: matches infra/docker/docker-compose.yml defaults
DATABASE_URL=postgresql://stagelink:stagelink@localhost:5432/stagelink_dev

# WorkOS AuthKit (required when auth is implemented)
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:4001/api/auth/callback

# Stripe (required when billing is implemented)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PostHog Analytics
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# S3-compatible Storage (AWS S3 or MinIO for local)
AWS_S3_BUCKET=stagelink-assets
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Local only — MinIO endpoint (leave empty for real AWS S3)
AWS_S3_ENDPOINT=

# Shopify Storefront API (Plan Pro)
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_STORE_DOMAIN=
