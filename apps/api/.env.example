# =============================================================
# StageLink API — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================

# Application
NODE_ENV=development
# APP_ENV explicitly names the deployment tier (development | staging | production).
# NODE_ENV is typically 'production' on staging servers — use APP_ENV for analytics filtering.
APP_ENV=development
PORT=4001
APP_URL=http://localhost:4001
FRONTEND_URL=http://localhost:4000

# PostgreSQL (required in production)
# Local: matches infra/docker/docker-compose.yml defaults
DATABASE_URL=postgresql://stagelink:stagelink@localhost:5432/stagelink_dev

# WorkOS AuthKit (required when auth is implemented)
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:4001/api/auth/callback

# Stripe (required when billing is implemented)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ID=
STRIPE_PRICE_PRO_PLUS_ID=

# PostHog Analytics
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# S3-compatible Storage
# For AWS S3: leave AWS_S3_ENDPOINT empty
# For MinIO (local dev): set AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=stagelink-assets
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
# Public base URL served to browsers (can be CDN like Cloudflare R2 or CloudFront)
# AWS example: https://stagelink-assets.s3.us-east-1.amazonaws.com
# Cloudflare R2 example: https://assets.stagelink.io
AWS_S3_PUBLIC_BASE_URL=https://stagelink-assets.s3.us-east-1.amazonaws.com

# Shopify Storefront API (Plan Pro)
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_STORE_DOMAIN=

# StageLink Insights
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TOP_TRACKS_MARKET=US
YOUTUBE_DATA_API_KEY=
# Optional — enables SoundCloud reference connection flow (public API v2 client ID)
SOUNDCLOUD_CLIENT_ID=
