{
  "name": "stagelink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter \"./packages/*\" build && pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --recursive --filter \"./packages/*\" build && pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "test": "pnpm --recursive test",
    "test:api": "pnpm --filter @stagelink/api test",
    "test:api:coverage": "pnpm --filter @stagelink/api test:coverage",
    "test:api:integration": "pnpm --filter @stagelink/api test:integration",
    "test:web": "pnpm --filter @stagelink/web test",
    "test:web:coverage": "pnpm --filter @stagelink/web test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "perf:load": "node scripts/performance/run-performance.mjs --profile load",
    "perf:stress": "node scripts/performance/run-performance.mjs --profile stress",
    "perf:scalability": "node scripts/performance/run-performance.mjs --profile scalability",
    "data:validate": "node scripts/data/run-data-integrity.mjs",
    "data:backup:dry-run": "bash scripts/data/backup-recovery.sh backup",
    "data:backup": "bash scripts/data/backup-recovery.sh backup",
    "data:restore:dry-run": "bash scripts/data/backup-recovery.sh restore-check",
    "data:restore:check": "bash scripts/data/backup-recovery.sh restore-check",
    "playwright:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}
